# Clean URLs — serve /contact-us instead of /contact-us.html
# Local XAMPP: keep RewriteBase as /dinsion-ui/
# Live site at domain root: change to RewriteBase /

Options -MultiViews
RewriteEngine On
RewriteBase /dinsion-ui/

# Redirect .html URLs to clean URLs (keeps one canonical address)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Don't rewrite real files or folders
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f

# Map /page-name → page-name.html
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
